# ===========================================
# HEADCHECK AI - Environment Variables
# Copy this file to .env and fill in your values
# ===========================================

# -------------------------------------------
# DATABASE (Required)
# -------------------------------------------
DATABASE_URL="mysql://user:password@localhost:3306/headcheck"

# -------------------------------------------
# JWT & AUTHENTICATION (Required)
# -------------------------------------------
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# -------------------------------------------
# GOOGLE OAUTH (Required for Google Sign-in)
# -------------------------------------------
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# -------------------------------------------
# EMAIL - RESEND (Required for emails & notifications)
# -------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# -------------------------------------------
# AI / LLM (Required for AI responses)
# -------------------------------------------
# OpenAI (recommended)
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Alternative: Anthropic Claude
# ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# -------------------------------------------
# WEB PUSH NOTIFICATIONS (Optional but recommended)
# -------------------------------------------
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# -------------------------------------------
# CRON JOBS (Optional - for production)
# -------------------------------------------
CRON_SECRET="a-secure-random-string-for-cron-authentication"

# -------------------------------------------
# APPLICATION
# -------------------------------------------
NODE_ENV="development"          # development | production
PORT="3000"
APP_URL="http://localhost:3000" # Used for emails, redirects, etc.

# -------------------------------------------
# OPTIONAL - STRIPE (Future monetization)
# -------------------------------------------
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# -------------------------------------------
# OPTIONAL - AWS S3 (for file uploads)
# -------------------------------------------
# AWS_REGION="eu-west-3"
# AWS_ACCESS_KEY_ID="AKIA..."
# AWS_SECRET_ACCESS_KEY="..."
# S3_BUCKET_NAME="headcheck-uploads"